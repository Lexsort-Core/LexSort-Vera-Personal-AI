# VERA Pro Discord Bot — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it is in .gitignore

# ─── Discord ──────────────────────────────────────────────────────────────
# Your Discord bot's token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your Discord application's client ID (from Developer Portal > General Information)
DISCORD_CLIENT_ID=your_discord_client_id_here

# Your VERA Pro Discord server's Guild ID (right-click server > Copy Server ID)
DISCORD_GUILD_ID=your_discord_guild_id_here

# The Role ID for the "Beta Tester" role (right-click role > Copy Role ID)
DISCORD_TESTER_ROLE_ID=your_tester_role_id_here

# ─── Netlify / Site ───────────────────────────────────────────────────────
# Your production Netlify site URL (no trailing slash)
NETLIFY_SITE_URL=https://lexsort.com
